{
  "name": "@thereis/bcli",
  "version": "1.0.0",
  "description": "BigCommerce CLI — a swiss army knife for BigCommerce stores",
  "license": "BUSL-1.1",
  "author": "Lucas Reis",
  "type": "module",
  "bin": {
    "bcli": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thereis/bcli.git"
  },
  "bugs": {
    "url": "https://github.com/thereis/bcli/issues"
  },
  "homepage": "https://github.com/thereis/bcli#readme",
  "scripts": {
    "bcli": "bun src/cli.ts",
    "build": "bun build src/cli.ts --outdir dist --target node --minify && chmod +x dist/cli.js",
    "dev": "bun src/cli.ts",
    "format": "biome format ./src --write",
    "lint": "biome check ./src --write",
    "lint:check": "biome check ./src",
    "test": "bun test --preload ./src/test-setup.ts",
    "ts-check": "tsc --noEmit",
    "check": "pnpm run ts-check && pnpm run lint:check && pnpm run test",
    "prepublishOnly": "pnpm run check && pnpm run build"
  },
  "keywords": [
    "bigcommerce",
    "bcli",
    "cli",
    "ecommerce",
    "export",
    "import",
    "customers",
    "orders",
    "products",
    "catalog",
    "bigcommerce-api",
    "mcp",
    "automation",
    "devtools"
  ],
  "packageManager": "pnpm@10.15.0",
  "engines": {
    "node": ">=20.11"
  },
  "dependencies": {
    "@t3-oss/env-core": "0.13.11",
    "csv-parse": "6.2.1",
    "csv-stringify": "6.7.0",
    "got": "15.0.3",
    "incur": "0.4.3",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/bun": "latest",
    "typescript": "5.9.3"
  }
}
